# syntax=docker/dockerfile:1.24
#
# cicd-sensor CI agent image (BPF-based observation agent).
#
# Runtime requires CAP_BPF + CAP_PERFMON + cgroup v2 access.

FROM --platform=${BUILDPLATFORM:-linux/amd64} cgr.dev/chainguard/go:latest@sha256:347466a55d59f92b7ba304efc5eb84ea675a73799c44d1691c6aff60203f9ed5 AS builder
WORKDIR /src

COPY go.mod go.sum ./
COPY vendor ./vendor
COPY cmd ./cmd
COPY internal ./internal

ARG TARGETOS=linux
ARG TARGETARCH=amd64
ARG VERSION=dev

ENV CGO_ENABLED=0
RUN --mount=type=cache,target=/root/.cache/go-build \
    GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build \
        -mod=vendor \
        -trimpath \
        -buildvcs=false \
        -ldflags="-s -w -X github.com/cicd-sensor/cicd-sensor/internal/version.Current=${VERSION}" \
        -o /out/cicd-sensor \
        ./cmd/cicd-sensor && \
    GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build \
        -mod=vendor \
        -trimpath \
        -buildvcs=false \
        -ldflags="-s -w -X github.com/cicd-sensor/cicd-sensor/internal/version.Current=${VERSION}" \
        -o /out/cicd-sensorctl \
        ./cmd/cicd-sensorctl

FROM cgr.dev/chainguard/static:latest@sha256:77d8b8925dc27970ec2f48243f44c7a260d52c49cd778288e4ee97566e0cb75b
COPY --from=builder /out/cicd-sensor /usr/local/bin/cicd-sensor
COPY --from=builder /out/cicd-sensorctl /usr/local/bin/cicd-sensorctl

ENTRYPOINT ["/usr/local/bin/cicd-sensor"]
